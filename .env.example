# Copy this file to .env and fill in real values. Never commit the real .env —
# it's already in .gitignore. Every key here has a corresponding field (and
# a safe fallback default) in backend/config.py — see there for details.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Academic Comeback
APP_ENV=development
APP_URL=http://127.0.0.1:8000
APP_SECRET_KEY=generate_a_random_256_bit_string_here
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://127.0.0.1:5500,http://localhost:5500,https://your-production-domain.example

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://username:password@cluster.example.mongodb.net/?appName=Cluster0
DB_NAME=academic_comeback

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=generate_a_strong_random_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
JWT_DOWNLOAD_EXPIRE_MINUTES=10

# ── Flutterwave V4 ─────────────────────────────────────────────────────────
FLW_CLIENT_ID=your-flutterwave-client-id
FLW_CLIENT_SECRET=your-flutterwave-client-secret
FLW_ENCRYPTION_SECRET=
FLW_WEBHOOK_SECRET_HASH=set-this-in-flutterwave-dashboard-settings-webhooks
FLW_VIRTUAL_ACCOUNT_BANK_CODE=035
PRODUCT_PRICE_NAIRA=2000
PRODUCT_PRICE_LATE_NAIRA=5000

# ── Meta Conversions API — main funnel Purchase event (optional; no-ops if blank) ──
FB_PIXEL_ID=
FB_CAPI_ACCESS_TOKEN=

# ── Meta Conversions API — affiliate registration CompleteRegistration event (optional) ──
FB_AFFILIATE_PIXEL_ID=
FB_AFFILIATE_CAPI_ACCESS_TOKEN=

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_USER=your@example.com
SMTP_PASS=your-smtp-password
FROM_EMAIL=Your Name <your@example.com>

# ── Admin ────────────────────────────────────────────────────────────────────
# The app refuses to start in production if ADMIN_PASSWORD still matches the
# hardcoded default in config.py — always set a real, unique value.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=set-a-strong-unique-password-here

# ── WhatsApp ─────────────────────────────────────────────────────────────────
WHATSAPP_CHANNEL_LINK=https://chat.whatsapp.com/your-channel-link
WHATSAPP_COMMUNITY_LINK=https://chat.whatsapp.com/your-community-link

# ── File Storage ─────────────────────────────────────────────────────────────
UPLOADS_DIR=uploads/products
MAX_FILE_SIZE_MB=50

# ── Affiliates ───────────────────────────────────────────────────────────────
AFFILIATE_DEFAULT_COMMISSION_PERCENT=60.0
AFFILIATE_VIDEO_MATERIALS_LINK=https://drive.google.com/your-folder-link
WHATSAPP_AFFILIATE_LINK=https://chat.whatsapp.com/your-affiliate-link

# ── Settlement (your own payout destination for withdraw-share jobs) ─────────
SETTLEMENT_BANK_CODE=
SETTLEMENT_ACCOUNT_NUMBER=
SETTLEMENT_ACCOUNT_NAME=
